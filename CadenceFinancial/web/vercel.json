{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/financial/api/:path*", "destination": "/api/:path*" },
    { "source": "/financial", "destination": "/index.html" },
    { "source": "/financial/:path*", "destination": "/:path*" },
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ]
}
