{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/fitness", "destination": "/index.html" },
    { "source": "/fitness/:path*", "destination": "/:path*" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
