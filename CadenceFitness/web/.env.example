# Copy to .env and fill from Supabase -> Project Settings -> API.
# Use a NEW, dedicated Supabase project for Cadence Fitness -- do not reuse
# the Cadence task-app or Cadence Financial projects. Each Cadence app gets
# its own isolated backend.
VITE_SUPABASE_URL=https://YOUR-FITNESS-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Local-only demo mode: shows fictional seed data without needing Supabase.
# Never set this in a deployed environment.
VITE_DEMO=1
